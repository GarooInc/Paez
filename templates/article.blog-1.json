    "f78e2552-9dc7-459c-9b1c-05d9d009dabb": {
      "type": "custom-image-with-text",
      "blocks": {
        "template--16695234232565__f78e2552-9dc7-459c-9b1c-05d9d009dabb-1676539204e31e7f26-1": {
          "type": "text",
          "settings": {
            "text": "<p>From Mary Janes to Espadrilles, to Sandals, to Mocs, to our Mules, at Paez, we believe in creating stylish, comfortable, and responsibly-made footwear that not only feels good on your feet but also has minimal impact on the environment. Every step of our process is carefully considered to ensure that we’re providing you with the best products.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "template--16695234232565__f78e2552-9dc7-459c-9b1c-05d9d009dabb-1676539204e31e7f26-1"
