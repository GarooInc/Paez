    "8a70fb08-d36d-44b3-b5b6-1d37543eb0bb": {
      "type": "custom-image-with-text",
      "blocks": {
        "e9425c6e-d97b-4574-bf7e-8e98e684f57a": {
          "type": "text",
          "settings": {
            "text": "<p><em><strong>Q: </strong></em><strong>Can you share insights into your creative process when starting a new project?</strong></p><p><br/><strong>A:</strong>While my personal works are often intuitive and spontaneous, client projects begin with extensive research and proposal development, all while infusing my sensibility and artistic taste.</p><p><em><strong><br/>Q: </strong></em><strong>How do you incorporate responsibility in your work as an artist and designer, particularly regarding production?</strong></p><p><br/><strong>A:</strong> Responsibility is ingrained in everything I do. From minimizing waste in materials, paint, and packaging to repurposing leftovers, I ensure that every aspect of production is handled responsibly.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "e9425c6e-d97b-4574-bf7e-8e98e684f57a"
      ],
