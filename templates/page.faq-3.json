    "44c817dd-2927-4d98-ad36-79500eac068e": {
      "type": "FAQ-template",
      "blocks": {
        "0ae00ece-feac-4e45-871f-33d938c47d19": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "IN WHAT CURRENCIES CAN I PAY FOR MY ORDER?",
            "block_description_question": "At the moment we only accept Euros (€), but we are working to enable payments with more currencies."
          }
        },
        "7653fe88-b25e-4d7c-94b3-3e66cc690395": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "WHAT PAYMENT METHODS DO YOU ACCEPT?",
            "block_description_question": "We accept VISA, Mastercard, PayPal, Amazon Pay, Apple Pay and Google Pay.<br><br>\n\nWe are working on enabling more payment references. Stay tuned!"
          }
        },
        "8a9dbf2c-352a-4d01-966d-449fa6e4b9b4": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "IS IT SAFE TO MAKE PAYMENTS ON YOUR WEBSITE?",
            "block_description_question": "Fully, our website uses SSL and you can pay with credit/debit card or PayPal.<br><br>\n\nDo not worry! :)"
          }
        }
      },
