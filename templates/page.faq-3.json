    "8981c527-1995-4112-9aa3-d49b27387282": {
      "type": "FAQ-template",
      "blocks": {
        "template--16712389361909__8981c527-1995-4112-9aa3-d49b27387282-1678507921c696fa7c-0": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "MY COUPON OR DISCOUNT DOESN’T WORK",
            "block_description_question": "If you’re having trouble applying a coupon or a discount code to your order, no need to worry! Just send us an email, with all relevant information to <a href=\"mailto:onlineshop@paez.com\" style=\"text-decoration: underline; color: black; font-weight: bold;\">onlineshop@paez.com</a> and we’ll take care of the rest.<br><br>\n\nIf you have a promocode, it can only be used in products that aren't on discount. Discounts are not cumulative."
          }
        },
        "template--16712389361909__8981c527-1995-4112-9aa3-d49b27387282-1678507921c696fa7c-1": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "HOW DO I APPLY A DISCOUNT COUPON OR PROMO CODE?",
            "block_description_question": "You can add a discount coupon or a promo code in two different stages of finishing your purchase. When reviewing your shopping cart, or during checkout. After applying your code, the discount will be deducted automatically from the amount."
          }
        },
        "template--16712389361909__8981c527-1995-4112-9aa3-d49b27387282-1678507921c696fa7c-2": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "THE PAEZ I WANT ARE OUT OF STOCK",
            "block_description_question": "Oh geez, we're sad to hear about that (but at the same, good on us, right?)<br><br>\n\nWhile we’re unable to provide specific dates for restocks, you can always stay on top of any news, by subscribing to our newsletter."
          }
        },
        "template--16712389361909__8981c527-1995-4112-9aa3-d49b27387282-1678507921c696fa7c-3": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "DO I NEED TO CREATE AN ACCOUNT TO ORDER?",
            "block_description_question": "You don’t have to create an account to order. But if you do, you can enjoy the following features:<br>\n• Order history<br>\n• Save your address, for quicker purchases<br>\n• Access to your wishlist"
          }
        }
      },
