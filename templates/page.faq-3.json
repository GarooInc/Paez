    "967bb6e5-05dc-402d-a55c-548f7f6f5ee4": {
      "type": "FAQ-template",
      "blocks": {
        "template--16694144172277__967bb6e5-05dc-402d-a55c-548f7f6f5ee4-167760235587cda456-0": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "HOW CAN I CANCEL MY ORDER?",
            "block_description_question": "Made a mistake and need to cancel your order? It happens to the best of us (hope you don’t regret it though!).<br>\nIf your order hasn’t been processed yet, we’ll try to cancel during the 24-hour period after you completed your order, and we’ll always try to it before it leaves our warehouse!<br>\nSend us an email to <a href=\"mailto:onlineshop@paez.com\">onlineshop@paez.com</a> with your order number indicating that you want to cancel your order and we will let you know if we are able to do so.<br><br>\nWe know that such errors can happen, but please understand that due to logistical reasons we may not be able to cancel your order as quickly as we would like. Rest assured that we want you to be satisfied at all times."
          }
        },
        "faq_left_VE3Eih": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "I DIDN’T RECEIVE A CONFIRMATION E-MAIL FROM YOU GUYS!",
            "block_description_question": "That shouldn’t happen at all! Most customers receive a confirmation e-mail within the first thirty minutes of completing their purchase.<br><br>\n\nThere are some cases where the confirmation e-mail ends up in the spam folder, depending on your e-mail provider and/or configurations. Before contacting the team at <a href=\"mailto:onlineshop@paez.com\">onlineshop@paez.com</a> please check it first.<br><br>\n\nIf not, please bear in mind that we’ll always do our best to assist you! We want you with our shoes, looking your very best (that’s why we do what we do!)"
          }
        },
        "faq_left_amKAMr": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "I DON’T HAVE ANY NEWS FOR YOU GUYS OVER MY ORDER, AND ENOUGH TIME HAS PASSED",
            "block_description_question": "Another situation that shouldn’t happen… at all! And we apologize so much for it. But it can happen, because we’re all human, and we can make mistakes as much as we work hard to avoid it. With that being said, there’s always a solution. Reach out to us if you haven’t received any communications from us in three business days."
          }
        }
      },
