    "e75a43d5-2b07-4cf0-8bf0-ed29892eefe1": {
      "type": "FAQ-template",
      "blocks": {
        "template--16694144172277__e75a43d5-2b07-4cf0-8bf0-ed29892eefe1-1676399562c07124e0-0": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "CAN I CHANGE MY PAEZ.COM ORDER?",
            "block_description_question": "At Paez we don't do direct exchanges. You can return your order within 30 days of receiving it. If you'd like to return your Paez order, check the <a href=\"#\" style=\"text-decoration: underline; color: black; font-weight: bold;\">Return Policy</a>.<br><br>\n\nIf both shoes and packaging are in perfect condition we will refund you right away. You can then purchase your new article.<br><br>\n\nPlease do not use the shoebox as your shipping package.<br><br>\n\nYou can contact <a href=\"mailto:onlineshop@paez.com\" style=\"text-decoration: underline; color: black; font-weight: bold;\">onlineshop@paez.com</a> anytime for any assistance.<br><br>\n\nIf your product was purchased with a promotion, you can return it and after confirmation, we will give you a code for the new purchase."
          }
        },
        "template--16694144172277__e75a43d5-2b07-4cf0-8bf0-ed29892eefe1-1676399562c07124e0-2": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "HOW DO I RETURN MY ORDER PURCHASED AT PAEZ.COM?",
            "block_description_question": "Check our <a href=\"https://returns.itsrever.com/paez\" style=\"text-decoration: underline; color: black; font-weight: bold;\">Returns Policy</a> and find out how you can return your item in less than three minutes!"
          }
        },
        "template--16694144172277__e75a43d5-2b07-4cf0-8bf0-ed29892eefe1-1676399562c07124e0-3": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "WHY CAN’T I EXCHANGE ITEMS THROUGH THE ONLINE SERVICE?",
            "block_description_question": "The PAEZ team is currently hard at work on finding sustainable solutions for exchanging purchased items (trust us, we want you happy all throughout the shopping process). However, operating with exchanges is quite costly at the moment and unfortunately not financially viable."
          }
        },
        "e908aad5-73f8-478a-bb05-d8dcdd220b12": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "I BOUGHT A PAEZ PRODUCT IN ANOTHER STORE AND IT HAS A DEFECT, CAN I RETURN IT?",
            "block_description_question": "Gosh, we’re truly sorry to hear about your Paez (we try as much as we can to reduce the risk of having defects). Unfortunately, we’re unable to help you directly in this matter. Please return to the store where you made your purchase with the product along with your receipt so that they can assist you properly.\n<br><br>\n\nIf you have any further questions please do not hesitate to contact us at onlineshop@paez.com."
          }
        }
      },
