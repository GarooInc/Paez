    "2d8ad0b2-a903-461f-aeff-bb96b95630ac": {
      "type": "FAQ-template",
      "blocks": {
        "template--16712389361909__2d8ad0b2-a903-461f-aeff-bb96b95630ac-1678507921c696fa7c-0": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "WHAT’S THE SHIPPING PRICE?",
            "block_description_question": "Please click <a href=\"https://paez.com/pages/shipping-policy\" style=\"text-decoration: underline; color: black; font-weight: bold;\">here</a> to find more about the shipping for different countries."
          }
        },
        "template--16712389361909__2d8ad0b2-a903-461f-aeff-bb96b95630ac-1678507921c696fa7c-1": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "WHERE DO YOU SHIP?",
            "block_description_question": "We ship to all countries inside the EU, and selected non-EU countries (Switzerland, and Turkey).<br><br>\n\nPlease note that shipping towards non-EU countries and select regions in EU that are subject to a customs clearance process (including Andorra, Canary Islands, Norway, and Serbia) may be subject to additional duties, taxes, or fees imposed that are not covered by Paez. We recommend checking with your local customs office for more information."
          }
        },
        "template--16712389361909__2d8ad0b2-a903-461f-aeff-bb96b95630ac-1678507921c696fa7c-2": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "WHAT DO I HAVE TO DO IF I HAVE NOT RECEIVED AN ORDER CONFIRMATION EMAIL ONCE I HAVE PURCHASED A PAEZ?",
            "block_description_question": "Oops! We usually send a confirmation email very quickly, so if you haven't received an email check your spam just in case!<br><br>\n\nIf it is not there, send us an email to <a href=\"mailto:onlineshop@paez.com\" style=\"text-decoration: underline; color: black; font-weight: bold;\">onlineshop@paez.com</a> and we will check if there has been any error."
          }
        },
        "a5214eef-1493-49f5-855c-27e76f58ce72": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "WHAT IS THE ESTIMATED DAY OF DELIVERY?",
            "block_description_question": "The expected day of delivery can be seen in the checkout process, for the location you want your Paez delivered or <a href=\"https://paez.com/pages/shipping-policy\" style=\"text-decoration: underline; color: black; font-weight: bold;\">here</a>."
          }
        }
      },
