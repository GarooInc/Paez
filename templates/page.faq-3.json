    "bbaaa71d-ff03-4ca5-a8f5-116ea2a64759": {
      "type": "FAQ-template",
      "blocks": {
        "1ea6b4d6-0a12-4242-9572-9ef5b74ed1f8": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "HOW DO I CLEAN MY PAEZ?",
            "block_description_question": "Easy peasy lemon squeezy. Please check <a href=\"https://paez.com/pages/product-care\" style=\"text-decoration: underline; color: black;\">here</a> how to properly wash your Paez."
          }
        },
        "33723f5b-3550-470b-9553-788eb1b4ce92": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "HOW DO I FIND MY SIZE?",
            "block_description_question": "Don’t know your size? No need to worry. Check our size guide <a href=\"https://paez.com/pages/size-guide\" style=\"text-decoration: underline; color: black; font-weight: bold;\">here</a>."
          }
        },
        "adf6243c-2092-482c-a94f-e5bbf07d0188": {
          "type": "faq_left",
          "settings": {
            "block_title_question": "HOW DO I KNOW IF MY PAEZ FIT?",
            "block_description_question": "In doubt, we recommend trying your Paez at home first (please don't take off the tag and keep the soles of the shoes as clean as you received them!). They loosen up and mould to your feet in just 20 minutes. Just like any other fabric, they'll adjust if needed (but if there's no pressure, they won't widen).<br><br>\n\nIf you're worried about a tight fit, go ahead and size up for a roomier feel. The chances of them widening too much are super slim. And hey, if they're not slipping off your feet while you walk, that's a popular choice among some of our customers.<br><br>\n\nIf you feel any immediate discomfort or tightness around the area of your toes, try sizing up for a comfier fit. No sweat! But please don't force the fabric (we don't want those holes in the fabric, do we?)"
          }
        }
      },
