    "ac86e1fa-1121-43b3-90c7-bf1ca4009b0a": {
      "type": "custom-image-with-text",
      "blocks": {
        "139e407d-9b47-4873-bcde-613e5f702443": {
          "type": "text",
          "settings": {
            "text": "<p>Another one of our absolute favourites is definitely JAC Brunch. </p><h6></h6><h6></h6><h6></h6><p>A very welcoming place near Principe Real, where you can start your late mornings (we get it, we love to sleep too), and we definitely recommend (after hugging one of the giant brown bears they have lying around the place) you have the banana-based/cream-cheesy Velvet Pancakes, or split their Salmon Tartare with a special person (side-eyeing).</p><h6></h6><p> If you're really really hungry though how about a pulled pork sandwich? Who cares? You'll walk it off throughout the day. </p><p>Go for it.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "139e407d-9b47-4873-bcde-613e5f702443"
      ],
      "custom_css": [
        "@media (max-width: 425px) {.grid {display: flex; flex-direction: column; }}",
        ".image-with-text .grid__item {position: relative; align-self: center;}"
      ],
      "settings": {
