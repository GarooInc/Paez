    "rich_text_4_gnXbFz": {
      "type": "rich-text-4",
      "settings": {
        "custom_class": "about-collection-banner-title page-banner-title",
        "prefix": "",
        "section_title": "",
        "section_sub": "",
        "description": "<h6><br/><br/><br/><br/><br/>Lisbon is not merely a city; it's a living, breathing entity that pulsates with life, humor, and an unmistakable charm. <br/><br/>Each of these carefully curated suggestions is a brushstroke on the canvas of Lisbon's allure.<br/><br/>It's part 2 of our blog to help you visit the best that Lisbon has to offer!<br/><br/>Make sure you pick up your Paez and walk alongside our hometown.</h6>",
        "section_url": ""
      }
    },
    "rich_text_4_Ebt38f": {
      "type": "rich-text-4",
      "settings": {
        "custom_class": "about-collection-banner-title page-banner-title",
        "prefix": "",
        "section_title": "Ready for an afternoon delight? Come explore these places",
        "section_sub": "",
        "description": "",
        "section_url": ""
      }
