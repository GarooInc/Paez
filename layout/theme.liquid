          if (!product.querySelector('.label-sale')) {
            const badge = document.createElement('figure');
            badge.className = 'absolute uppercase label-sale text-center';
            badge.style = 'position: absolute; top: 0; left: 0; background: #E63946; color: #fff; padding: 5px 10px; z-index: 10; font-weight: bold;';
            badge.innerText = '-30% OFF';
            const imgWrapper = product.querySelector('.img-product') || product.querySelector('.usf-img-wrapper');
            if (imgWrapper) {
              imgWrapper.appendChild(badge);
            }
          }
        });
      });
    } catch (e) {
      console.warn('[DADWEEK badge] Error al inyectar badges:', e);
