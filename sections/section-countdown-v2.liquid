<div data-section-id="{{ section.id }}" data-section-type="section-countdown-v2" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{section.settings.sections_bg_color}};{% endif %}">
  <div class="section-countdown-v2 mt-all" style="background-image: url( {%if section.settings.img_banner1 != blank %}{{section.settings.img_banner1 | img_url: 'master'}} {% else %}///via.placeholder.com/1920x850 {% endif %})">
    <div class="container container-v2">
      <div class="row ">
        <div class="col-lg-6">
          <div class="box-info-content text-center" style="background: {{section.settings.bg_section}}">
            <div class=" content-section">
              <div class=" info-deal">
                <div class="m-auto">
                  {% if section.settings.deal-to != blank %}
                  <div class="deal-to" style="color : {{section.settings.color_title}}">{{section.settings.deal-to}}</div>
                  {% endif %}
                  {% if section.settings.sub_banner != blank%}
                  <p class="sub-title" style="color: {{section.settings.color_sub1}}">{{section.settings.sub_banner}}</p>
                  {% endif %}
                </div>
              </div>

              <div class="countdown-timer text-center">
                <ul class="mb-0" data-countdown="countdown-v1" data-date="{{section.settings.countdown-date}}">

                </ul>
              </div>

              {% if section.settings.buttom_banner != blank %}
              <div class="div-button">
                <a class="button " href="{{section.settings.button_banner_url}}" style="color: {{section.settings.color_buttom_banner}}; background:{{section.settings.bgcolor_buttom_banner}};">
                  {{section.settings.buttom_banner}}
                </a>
              </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>


<style>
   .section-countdown-v2 .button {
    border : 1px solid {{section.settings.color_buttom_banner}} !important;
  }
  .section-countdown-v2 .button:hover {
    color : {{section.settings.hovercolor_buttom_banner}} !important;
    background : {{section.settings.hoverbgcolor_buttom_banner}} !important;
  }
  .section-countdown-v2 .countdown-timer li span
  {
    color: {{section.settings.color_countdown}} !important;

  }
  .section-countdown-v2 .countdown-timer li{
    color: {{section.settings.color_subcountdown}} !important;
  }
</style>  


{% schema %}
{
  "name": "COUNTDOWN V2",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Info Left"
    },
    {
      "type": "image_picker",
      "id": "img_banner1",
      "label": "Background Image",
      "info": "1920 x 750px recommended"
    },
    {
      "type": "header",
      "content": "Info Right"
    },
	{
      "type": "color",
      "id": "bg_section",
      "label": "Bacground Section",
      "default": "#c1582a"
    },
    {
      "type": "text",
      "id": "deal-to",
      "label": "Title",
      "default": "Organic Goods 50% Off"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Color Title"
    },
    {
      "type": "text",
      "id": "sub_banner",
      "label": "Title Banner",
      "default": "Way is there to get clothing you’re sure to love than by making it"
    },
    {
      "type": "color",
      "id": "color_sub1",
      "label": "Color Sub banner",
      "default": "#fff"
    },
    {
      "type": "header",
      "content": "Countdown Date"
    },
    {
      "type": "text",
      "id": "countdown-date",
      "label": "Enter the date you want",
      "info": "Format: Year-Month-Day-Hour-Minute-Second"
    },
    {
      "type": "color",
      "id": "color_countdown",
      "label": "Color time"
    },
    {
      "type": "color",
      "id": "color_subcountdown",
      "label": "Color sub time"
    },
    {
      "type": "text",
      "id": "buttom_banner",
      "label": "Button name",
      "default": "SHOP NOW"
    },
    {
      "type": "color",
      "id": "color_buttom_banner",
      "label": "Color Button"
    },
    {
      "type": "color",
      "id": "hovercolor_buttom_banner",
      "label": "Color hover Button"
    },
    {
      "type": "color",
      "id": "bgcolor_buttom_banner",
      "label": "Background Color Button"
    },
    {
      "type": "color",
      "id": "hoverbgcolor_buttom_banner",
      "label": "Background Color hover  Button"
    },
    {
      "type": "url",
      "id": "button_banner_url",
      "label": "URL button",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "presets": [
    {
      "name": "COUNTDOWN V2",
      "category": "HOME"
    }
  ]
}
{% endschema %}


{% stylesheet %}
{% endstylesheet %}

