<div data-section-id="{{ section.id }}" data-section-type="section-locations" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-locations mt-all {{ section.settings.custom_class }}">
    <div class="">
      {% if section.settings.title_heading != blank %}
      <div class="text-center">
        <h3 class="title_heading text-center mb-4" style="color: {{section.settings.color_title}}">{{section.settings.title_heading}}</h3>
      </div>
      {% endif %}
      
      <div class="locations-wrapper">
        <div class="row slider-locations">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              <div class="col-lg-3 col-md-4 col-sm-6 col-6 location-item" {{ block.shopify_attributes }}>
                <div class="location-card">
                  {% if block.settings.location_image != blank %}
                    <div class="location-image">
                      <img src="{{ block.settings.location_image | img_url: '400x400', crop: 'center' }}" 
                           alt="{{ block.settings.location_name }}"
                           loading="lazy">
                    </div>
                  {% else %}
                    <div class="location-image placeholder">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                    </div>
                  {% endif %}
                  
                  <div class="location-content">
                    {% if block.settings.location_name != blank %}
                      <h4 class="location-name">{{ block.settings.location_name }}</h4>
                    {% endif %}
                    
                    {% if block.settings.location_description != blank %}
                      <p class="location-description">{{ block.settings.location_description }}</p>
                    {% endif %}
                    
                    {% if block.settings.location_link != blank %}
                      <a href="{{ block.settings.location_link }}" class="location-link" {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
                        {{ block.settings.link_text | default: "How to get there" }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            {% for i in (1..4) %}
              <div class="col-lg-3 col-md-4 col-sm-6 col-6 location-item">
                <div class="location-card">
                  <div class="location-image placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                  </div>
                  <div class="location-content">
                    <h4 class="location-name">Location Name</h4>
                    <p class="location-description">Add your location description here</p>
                    <a href="#" class="location-link">How to get there <i class="fa fa-arrow-right"></i></a>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>

  .locations-wrapper{
    margin: 20px 0;
  }

  .location-card {
    background: #fff;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  
  .location-image {
    width: 100%;
    height: 400px;
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
  }
  
  .location-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .location-image.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  
  .location-image.placeholder svg {
    width: 60px;
    height: 60px;
    color: #ccc;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  
  .location-content {
    padding: 20px 0;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .location-name {
    font-size: 18px;
    font-weight: 400;
    margin: 0 0 10px 0;
    color: #222;
  }
  
  .location-description {
    font-size: 14px;
    color: #666;
    margin: 0 0 15px 0;
    flex: 1;
    line-height: 1.5;
  }
  
  .location-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #000;
    text-decoration: underline;
    font-size: 14px;
    font-weight: 500;
  }
  
  .location-link:hover {
    color: #000;
    text-decoration: underline !important;

  }
  
  .location-link i {
    transition: transform 0.3s ease;
  }
  
  .location-link:hover i {
    transform: translateX(5px);
        text-decoration: underline;

  }
  
  .location-item {
    margin-bottom: 30px;
  }

    .slider-locations .next-slide,
  .slider-locations .prev-slide {
      display: flex;
      justify-content: center;
      position: absolute;
      top: 50%;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      background-color: #000;
      align-items: center;
      transform: translate(0, -50%);
      z-index: 1;
  }
  
  .slider-locations .next-slide {
    right: 40px;
  }
  
  .slider-locations .prev-slide {
    left: 40px;
  }
  
  .slider-locations .next-slide:hover,
  .slider-locations .prev-slide:hover {
    background: #000;
    color: #fff;
    border-color: #000;
  }

  .fa-angle-right:before{
    color: #fff;
  }
  
  .slider-locations .next-slide i,
  .slider-locations .prev-slide i {
    font-size: 20px;
    line-height: 1;
    color: #fff;
  }

  @media (max-width: 576px) {
    .slider-locations .next-slide,
  .slider-locations .prev-slide{
        width: 20px;
        height: 20px;
    }

    .slider-locations .next-slide i,
  .slider-locations .prev-slide i  {
        font-size: 16px;
    }
}
</style>

<script>
  $(document).ready(function() {
    {% if section.settings.enable_slider %}
      $('.slider-locations').slick({
        dots: false,
        arrows: true,
        infinite: true,
        speed: 300,
        autoplay: {{ section.settings.autoplay }},
        autoplaySpeed: {{ section.settings.autoplay_speed }},
        slidesToShow: 4,
        slidesToScroll: 1,
        nextArrow: '<button type="button" class="next-slide"><i class="fa fa-angle-right"></i></button>',
        prevArrow: '<button type="button" class="prev-slide"><i class="fa fa-angle-left"></i></button>',
        responsive: [
          {
            breakpoint: 1024,
            settings: {
              slidesToShow: 3,
              slidesToScroll: 1
            }
          },
          {
            breakpoint: 768,
            settings: {
              slidesToShow: 2,
              slidesToScroll: 1
            }
          },
          {
            breakpoint: 480,
            settings: {
              slidesToShow: 1,
              slidesToScroll: 1
            }
          }
        ]
      });
    {% endif %}
  });
</script>

{% schema %}
{
  "name": "Locations",
  "settings": [
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom Class"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "title_heading",
      "label": "Title Section",
      "default": "Our Locations"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Title Color",
      "default": "#222"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slider",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 8000,
      "step": 1000,
      "label": "Autoplay Speed (ms)",
      "default": 5000
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "image_picker",
          "id": "location_image",
          "label": "Location Image"
        },
        {
          "type": "text",
          "id": "location_name",
          "label": "Location Name",
          "default": "Location Name"
        },
        {
          "type": "textarea",
          "id": "location_description",
          "label": "Description",
          "default": "Add a brief description of this location"
        },
        {
          "type": "url",
          "id": "location_link",
          "label": "Link (Google Maps or directions)"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "How to get there"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Open link in new tab",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Locations",
      "category": "Custom",
      "blocks": [
        {
          "type": "location",
          "settings": {
            "location_name": "Main Store",
            "location_description": "Visit our flagship location downtown"
          }
        },
        {
          "type": "location",
          "settings": {
            "location_name": "North Branch",
            "location_description": "Find us in the northern district"
          }
        },
        {
          "type": "location",
          "settings": {
            "location_name": "East Location",
            "location_description": "Our newest store in the east side"
          }
        },
        {
          "type": "location",
          "settings": {
            "location_name": "West Branch",
            "location_description": "Serving the west community"
          }
        }
      ]
    }
  ]
}
{% endschema %}