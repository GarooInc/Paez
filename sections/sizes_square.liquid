<script>
$(document).ready(function(){
    // Inicialmente ocultar todas las tablas.
    $('.table-responsive').addClass('hidden-table');

    $('.nav-tabs a').click(function(e){
        e.preventDefault(); 
        var currentTab = $(this).attr('href'); 
        var table = $(currentTab).find('.table-responsive');

        // Si la tabla ya está visible, la oculta
        if (table.hasClass('hidden-table')) {

            $('.table-responsive').addClass('hidden-table');
            table.removeClass('hidden-table'); 
            $('.nav-tabs a').removeClass('active'); 
            $(this).addClass('active'); 
            $('.tab-pane').removeClass('show active'); 
            $(currentTab).addClass('show active'); 
        } else {
            table.addClass('hidden-table'); 
            $(this).removeClass('active'); 
            $(currentTab).removeClass('show active'); 
        }
    });
});

</script>

