

{%- if section.settings.show_section -%}
<section
  class="logo-marquee-section"
  id="section-{{ section.id }}"
  style="
    --marquee-bg: {{ section.settings.background_color }};
    --marquee-border-color: {{ section.settings.border_color }};
    --marquee-text-color: {{ section.settings.label_color }};
    --marquee-speed: {{ section.settings.speed }}s;
    --marquee-logo-height: {{ section.settings.logo_height }}px;
    --marquee-gap: {{ section.settings.gap }}px;
  "
>

  {%- if section.settings.label != blank -%}
    <div class="logo-marquee__label-wrapper">
      <span class="logo-marquee__label">
        {%- if section.settings.show_pulse -%}
          <span class="logo-marquee__pulse"></span>
        {%- endif -%}
        {{ section.settings.label }}
      </span>
    </div>
  {%- endif -%}

  <div class="logo-marquee__track-wrapper" aria-label="{{ section.settings.label | default: 'Logos' }}">
    <div class="logo-marquee__track">

      {%- comment %} Render logos twice for seamless loop {%- endcomment -%}
      {%- for _loop in (1..2) -%}
        <div class="logo-marquee__list" aria-hidden="{% if forloop.index == 2 %}true{% else %}false{% endif %}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'logo' -%}
              <div class="logo-marquee__item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="logo-marquee__link" aria-label="{{ block.settings.alt_text | default: 'Logo' }}" {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
                {%- endif -%}

                {%- if block.settings.logo != blank -%}
                  {%- assign logo_alt = block.settings.alt_text | default: block.settings.logo.alt | default: 'Logo' -%}
                  {{
                    block.settings.logo
                    | image_url: width: 400
                    | image_tag:
                      class: 'logo-marquee__img',
                      alt: logo_alt,
                      loading: 'lazy',
                      widths: '100, 150, 200, 300, 400',
                      sizes: '(max-width: 768px) 80px, 160px'
                  }}
                {%- else -%}
                  <div class="logo-marquee__placeholder">
                    {%- if block.settings.alt_text != blank -%}
                      <span>{{ block.settings.alt_text }}</span>
                    {%- else -%}
                      {% render 'icon-placeholder' %}
                      <span>Logo</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

</section>
{%- endif -%}


<style>
  #section-{{ section.id }} {
    background-color: var(--marquee-bg);
    border-top: 1px solid var(--marquee-border-color);
    border-bottom: 1px solid var(--marquee-border-color);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
  }

  /* ── Label ── */
  .logo-marquee__label-wrapper {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    padding: 0 20px 0 24px;
    position: relative;
    z-index: 2;
    border-right: 1px solid var(--marquee-border-color);
    background-color: var(--marquee-bg);
    height: 100%;
  }

  .logo-marquee__label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--marquee-text-color);
    white-space: nowrap;
  }

  /* Pulse dot */
  .logo-marquee__pulse {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ef4444;
    flex-shrink: 0;
    animation: marquee-pulse 1.5s ease-in-out infinite;
    box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
  }

  @keyframes marquee-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(239,68,68,0.5); }
    70%  { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
    100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); }
  }

  /* ── Track ── */
  .logo-marquee__track-wrapper {
    overflow: hidden;
    flex: 1;
    /* Fade edges */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 5%,
      black 95%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 5%,
      black 95%,
      transparent 100%
    );
  }

  .logo-marquee__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll var(--marquee-speed) linear infinite;
  }

  /* Pause on hover */
  #section-{{ section.id }}:hover .logo-marquee__track {
    animation-play-state: {% if section.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  .logo-marquee__list {
    display: flex;
    align-items: center;
    gap: var(--marquee-gap);
    padding: 0 calc(var(--marquee-gap) / 2);
  }

  /* ── Items ── */
  .logo-marquee__item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-marquee__link {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .logo-marquee__link:hover {
    opacity: 0.7;
    transform: scale(1.05);
  }

  .logo-marquee__img {
    height: var(--marquee-logo-height);
    width: auto;
    max-width: 180px;
    object-fit: contain;
    display: block;
    /* Grayscale option */
    filter: {% if section.settings.grayscale %}grayscale(100%) opacity(0.6){% else %}none{% endif %};
    transition: filter 0.3s ease;
  }

  {%- if section.settings.grayscale -%}
  .logo-marquee__item:hover .logo-marquee__img {
    filter: grayscale(0%) opacity(1);
  }
  {%- endif -%}

  /* Placeholder (no image uploaded) */
  .logo-marquee__placeholder {
    height: var(--marquee-logo-height);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 0 16px;
    background: rgba(128,128,128,0.1);
    border-radius: 4px;
    color: var(--marquee-text-color);
    font-size: 13px;
    font-family: sans-serif;
    white-space: nowrap;
    border: 1px dashed rgba(128,128,128,0.3);
  }

  /* ── Keyframe ── */
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Reverse direction */
  {%- if section.settings.direction == 'right' -%}
  .logo-marquee__track {
    animation-direction: reverse;
  }
  {%- endif -%}

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .logo-marquee__track {
      animation: none;
    }
    .logo-marquee__track-wrapper {
      -webkit-mask-image: none;
      mask-image: none;
      overflow-x: auto;
    }
  }
</style>


{% schema %}
{
  "name": "Logo Marquee",
  "tag": "section",
  "class": "logo-marquee-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Visibilidad"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Mostrar sección",
      "default": true
    },
    {
      "type": "header",
      "content": "Etiqueta del listón"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Texto de etiqueta",
      "default": "NUESTROS CLIENTES",
      "info": "Deja vacío para ocultar la etiqueta"
    },
    {
      "type": "checkbox",
      "id": "show_pulse",
      "label": "Mostrar punto animado (●)",
      "default": true
    },
    {
      "type": "header",
      "content": "Comportamiento"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidad (segundos por ciclo)",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 30,
      "info": "Número más bajo = más rápido"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Dirección",
      "options": [
        { "value": "left",  "label": "← Izquierda (predeterminado)" },
        { "value": "right", "label": "→ Derecha" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pausar al pasar el cursor",
      "default": true
    },
    {
      "type": "header",
      "content": "Logos"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Altura de logos (px)",
      "min": 24,
      "max": 100,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Separación entre logos (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Logos en escala de grises (color al hover)",
      "default": false
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color de borde",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Color de texto de etiqueta",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Imagen del logo"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Texto alternativo",
          "info": "Para accesibilidad y SEO"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (opcional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Abrir en nueva pestaña",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Marquee",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
