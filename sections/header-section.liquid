<section class="relative w-full h-screen min-h-[800px] 
    flex overflow-hidden full-bleed-header-section header-bg"
     style="--header-bg: url('{{ section.settings.background_image | image_url }}'); --text-color: {{ section.settings.text_color }};">
     
    <div class="flex flex-col w-full md:items-start items-center justify-center md:pt-55 pt-65">

        <div class="z-2 flex items-center gap-2 px-15">
            <div class="flex gap-1">
                {% for i in (1..5) %}
                <div class="md:w-6 md:h-6 w-4 h-4 bg-[#24b880] flex items-center justify-center">
                    <div class="md:w-4 md:h-4 h-3.5 w-3.5 ">
                        {% render 'star' %}
                    </div>
                </div>
                {% endfor %}
            </div>

            <div class="header-text md:text-lg text-sm font-medium text-black md:text-{{ section.settings.text_color }}">
                {{ section.settings.star_text }}
            </div>
        </div>

        <div class="z-2">
            <h1 class="header-text text-left md:px-15 text-5xl font-bold pt-10 text-black md:text-{{ section.settings.text_color }}" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
                {{ section.settings.page_title | newline_to_br }}
            </h1>
        </div>

        <div class="z-2">
            <p class="header-text text-left md:px-15 md:text-lg text-md md:pt-10 pt-5  text-black md:text-{{ section.settings.text_color }}">
                {{ section.settings.page_descripction }}
            </p>
        </div>

        <div class="flex z-2 pointer-events-none px-15 md:pt-5 pt-8">
            <a
            href="/"
            class="pointer-events-auto bg-white flex items-center justify-center 
                    rounded-xl md:px-8 md:py-2 py-3 px-10 hover:opacity-70 transition-opacity"
            >
                <span class="header-text text-lg uppercase">
                    {{ section.settings.button_text }}
                </span>
            </a>
        </div>
    </div>
    
    <div class="ticker-wrapper w-full absolute bottom-0 py-10 overflow-hidden">
      <div class="ticker-content" >
        {% for i in (1..10) %}
          {% if section.settings.ticker_image != blank %}
            <img 
              src="{{ section.settings.ticker_image | img_url: '200x' }}" 
              alt="{{ section.settings.logo_text }}"
              height="{{ section.settings.ticker_image.height }}"
              width="{{ section.settings.ticker_image.width }}"
              class="ticker-item h-9 w-20 object-contain"
              loading="lazy"
            >
          {% else %}
            <p class="ticker-item header-text text-xl">{{ section.settings.logo_text }}</p>
          {% endif %}
        {% endfor %}
        {% for i in (1..10) %}
          {% if section.settings.ticker_image != blank %}
            <img 
              src="{{ section.settings.ticker_image | img_url: '200x' }}" 
              alt="{{ section.settings.logo_text }}"
              height="{{ section.settings.ticker_image.height }}"
              width="{{ section.settings.ticker_image.width }}"
              class="ticker-item h-9 w-20 object-contain"
              loading="lazy"
            >
          {% else %}
            <p class="ticker-item header-text text-xl">{{ section.settings.logo_text }}</p>
          {% endif %}
        {% endfor %}
      </div>
    </div>
</section>

<style>


  
  .full-bleed-header-section {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  .header-bg {
    background-image: var(--header-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .header-bg {
      background-image: url('{{ section.settings.background_image_mobile | image_url }}');
    }
  }

  .ticker-wrapper {
    position: absolute;
    width: 100%;
    overflow: hidden;
  }

  .ticker-content {
    display: flex;
    gap: 5rem;
    animation: scroll-left {{ section.settings.ticker_speed }}s linear infinite;
    width: max-content;
    align-items: center;
  }

  .ticker-item {
    white-space: nowrap;
    flex-shrink: 0;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-wrapper:hover .ticker-content {
    animation-play-state: paused;
  }

  @media (max-width: 768px) {
    .ticker-content {
      gap: 3rem;
    }

    .ticker-item {
      height: 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Header main section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image desktop"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image mobile"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "Black", "label": "Black" },
        { "value": "White", "label": "White" }
      ],
      "default": "Black"
    },
    {
      "type": "richtext",
      "id": "star_text",
      "label": "Reviews Text"
    },
    {
      "type": "textarea",
      "id": "page_title",
      "label": "Page Title",
      "default": "Slide heading"
    },
    {
      "type": "text",
      "id": "page_descripction",
      "label": "Page Description",
      "default": "Tell a story"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    
  ],
  "presets": [
    {
      "name": "Header Main section"
    }
  ]
}
{% endschema %}