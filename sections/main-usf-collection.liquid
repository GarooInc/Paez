<script>
     $(function () {
             var $win = $(window);

             $win.scroll(function () {
                 if ($win.scrollTop() == 0)
                    console.log("top");
                 else if ($win.height() + $win.scrollTop()
                                == $(document).height()) {
                     $("a.btn-loadmore").click();
                 }
             });
         });

    $('.hover-img').hover(function() {
    var originalImage = $(this).attr('data-src');
    var hoverImage = $(this).attr('data-hover-src');

    $(this).attr('src', hoverImage);
    $(this).mouseout(function() {
        $(this).attr('src', originalImage);
    });
});
</script>

                
