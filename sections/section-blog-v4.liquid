<div data-section-id="{{ section.id }}" data-section-type="section-blog-v4" {% if section.settings.sections_layout=="dark" %}background: {{section.settings.sections_bg_color}};{% endif %}">
  <div class="section-blog-v4 {{ section.settings.css_class }}">
    <div class="container container-full">
      <div class="title-section text-center">
        {% if section.settings.section_title != blank %}
          <h3 class="title_heading" style="color: {{section.settings.color_title}}">{{ section.settings.section_title }}</h3>
        {% endif %}
      </div>
      <div class="blog-content row blog-slider-{{ section.id }}">
          {%- assign blog_selected = section.settings.select_blog -%}
          {% for article in blogs[blog_selected].articles %}
            <div class="blog-item">
              <div class="blog-item-inner">
                <div class="image">
                  <a href="{{ article.url }}" class="d-block">
                    <img src="{{ article.image.src | img_url: 'original' }}" alt="{{ article.title  }}" class="img-fluid w-100">
                  </a>
                </div>
                <div class="post post2">
                  <h4 class="article-title title2">
                    <a href="{{ article.url }}" class="d-block">{{article.title}}</a>
                  </h4>
                </div>
                {% if section.settings.button_name != blank %}
                  <a href="{{article.url}}" class="btn-readmore">{{section.settings.button_name}}</a>
                  {% endif %}
              </div>
            </div>
          {% endfor %}
      </div>
  </div>
</div>
</div>

<script>
$('.blog-slider-{{ section.id }}').slick({
  dots: false,
  arrows: true,
  infinite: false,
  speed: 300,
  slidesToShow: 3,
  slidesToScroll: 1,
  prevArrow: '<button type="button" class="slick-prev slick-arrow"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/></svg></button>',
  nextArrow: '<button type="button" class="slick-next slick-arrow"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bi bi-arrow-right" viewBox="0 0 16 16">  <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/></svg></button>',
  responsive: [
      {
          breakpoint: 750,
          settings: {
              slidesToShow: 1,
              slidesToScroll: 1
          }
      },
      {
          breakpoint: 750,
          settings: {
              slidesToShow: 1,
              slidesToScroll: 1
          }
      }
  ]
});
</script>
{% schema %}
{
  "name": "BLOG V4",
  "settings": [
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS Class"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Our Blog"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Color",
      "default": "#fff"
    },
    {
      "type": "blog",
      "id": "select_blog",
      "label": "Select Blog"
    },
    {
      "type": "text",
      "id": "button_name",
      "label": "Button name",
      "default": "Read More"
    }
  ],
	"presets": [
    {
      "name": "BLOG V4",
      "category": "HOME"
    }
  ]
}
{% endschema %}

