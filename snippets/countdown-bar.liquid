<div id="countdown-bar" style="display:none;">
  <span class="countdown-text">⏳ Dad Week ends in:</span>
  <span id="countdown-timer"></span>
</div>

<style>
  #countdown-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background-color: #000;
    color: #fff;
    text-align: center;
    padding: 12px 16px;
    font-size: 14px;
    font-weight: 600;
    z-index: 9999;
    letter-spacing: 0.05em;
  }
  #countdown-timer {
    font-size: 18px;
    font-weight: 700;
    margin-left: 8px;
  }
</style>

<script>
  (function() {
    var endDate = new Date('2026-03-19T23:59:00+00:00');
    var fortyEightHours = 48 * 60 * 60 * 1000;

    function update() {
      var now = new Date();
      var diff = endDate - now;

      if (diff <= 0 || diff > fortyEightHours) {
        document.getElementById('countdown-bar').style.display = 'none';
        return;
      }

      document.getElementById('countdown-bar').style.display = 'block';

      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      document.getElementById('countdown-timer').textContent =
        h + 'h ' + m + 'm ' + s + 's';
    }

    update();
    setInterval(update, 1000);
  })();
</script>